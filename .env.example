# Copy to .env.local and fill in. .env.local is gitignored.

# Apify — sourcing + evidence scrapers
APIFY_TOKEN=

# OpenAI — counterfactual, founder summary, outreach draft
OPENAI_API_KEY=

# InsForge — Postgres, realtime, email
NEXT_PUBLIC_INSFORGE_URL=
NEXT_PUBLIC_INSFORGE_ANON_KEY=
INSFORGE_API_KEY=

# Outreach send gate (v1, no auth): send refused unless this is set AND request carries matching x-outreach-token
OUTREACH_SEND_TOKEN=
# Copilot credit-spend gate: copilot-initiated diligence disabled unless this is exactly "true"
COPILOT_DILIGENCE_ENABLED=
